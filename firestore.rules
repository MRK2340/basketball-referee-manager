rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isManager() {
      return isAuth() && getRole() == 'manager';
    }

    function isReferee() {
      return isAuth() && getRole() == 'referee';
    }

    // Returns the set of fields that changed between the incoming write and the existing doc
    function changedFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() || resource.data.role == 'referee';
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId
        && !('role' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Meta (seed guard) ─────────────────────────────────────────────────────
    match /_meta/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && resource == null;
    }

    // ── Tournaments ───────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow create: if isManager()
        && request.resource.data.manager_id == request.auth.uid;
      allow update, delete: if isManager() && resource.data.manager_id == request.auth.uid;
    }

    // ── Games ─────────────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if isAuth();
      allow create: if isManager()
        && request.resource.data.manager_id == request.auth.uid;
      allow update: if isManager() && resource.data.manager_id == request.auth.uid;
      allow delete: if isManager() && resource.data.manager_id == request.auth.uid;
    }

    // ── Game Assignments ──────────────────────────────────────────────────────
    // Managers create with status 'assigned' and their own manager_id.
    // Referees create with status 'pending' and their own referee_id.
    // Referees can only update status + decline_reason on their own assignments.
    match /game_assignments/{assignmentId} {
      allow read: if isAuth();
      allow create: if isAuth() && (
        // Manager assigning a referee — must own the assignment
        (isManager()
          && request.resource.data.manager_id == request.auth.uid)
        ||
        // Referee requesting assignment — must be self, status must be pending
        (isReferee()
          && request.resource.data.referee_id == request.auth.uid
          && request.resource.data.status == 'pending')
      );
      allow update: if isAuth() && (
        // Managers can update any assignment field
        isManager()
        ||
        // Referees can only update status + decline_reason on their own assignments
        (request.auth.uid == resource.data.referee_id
          && changedFields().hasOnly(['status', 'decline_reason']))
      );
      allow delete: if isManager();
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.manager_id ||
         request.auth.uid == resource.data.referee_id);
      allow create: if isManager() &&
        request.resource.data.manager_id == request.auth.uid &&
        request.resource.data.amount is number &&
        request.resource.data.amount >= 0 &&
        request.resource.data.amount <= 10000;
      allow update: if isManager() && resource.data.manager_id == request.auth.uid;
    }

    // ── Messages ──────────────────────────────────────────────────────────────
    // Sender must be the authenticated user and must be in participants list.
    match /messages/{messageId} {
      allow read: if isAuth() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuth()
        && request.resource.data.sender_id == request.auth.uid
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() &&
        request.auth.uid in resource.data.participants;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.recipient_id;
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['recipient_id', 'type', 'title'])
        && (isManager() || request.resource.data.type == 'message');
      allow update: if isAuth() && request.auth.uid == resource.data.recipient_id;
    }

    // ── Referee Availability ──────────────────────────────────────────────────
    match /referee_availability/{availId} {
      allow read: if isAuth();
      allow create: if isReferee()
        && request.resource.data.referee_id == request.auth.uid;
      allow update, delete: if isReferee() &&
        request.auth.uid == resource.data.referee_id;
    }

    // ── Game Reports ──────────────────────────────────────────────────────────
    // Referee can update their own report fields (NOT resolution fields).
    // Manager can ONLY update resolution fields on reports they manage.
    match /game_reports/{reportId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.referee_id ||
         request.auth.uid == resource.data.manager_id);
      allow create: if isReferee()
        && request.resource.data.referee_id == request.auth.uid;
      allow update: if isAuth() && (
        // Referee: own report, cannot touch resolution fields
        (request.auth.uid == resource.data.referee_id
          && !changedFields().hasAny(['resolution_note', 'resolved_by', 'resolved_at']))
        ||
        // Manager: can only set resolution fields + status
        (isManager() && request.auth.uid == resource.data.manager_id
          && changedFields().hasOnly(['resolution_note', 'resolved_by', 'resolved_at', 'status']))
      );
    }

    // ── Referee Ratings ───────────────────────────────────────────────────────
    match /referee_ratings/{ratingId} {
      allow read: if isAuth() || true;
      allow create: if isManager() &&
        request.resource.data.manager_id == request.auth.uid &&
        request.resource.data.stars is number &&
        request.resource.data.stars >= 1 &&
        request.resource.data.stars <= 5;
      allow update: if isManager() && resource.data.manager_id == request.auth.uid &&
        request.resource.data.stars is number &&
        request.resource.data.stars >= 1 &&
        request.resource.data.stars <= 5;
    }

    // ── Manager Connections ───────────────────────────────────────────────────
    // Only referees can create. Only managers can update (approve/reject).
    // Either party can delete (withdraw/remove).
    match /manager_connections/{connId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.manager_id ||
         request.auth.uid == resource.data.referee_id);
      allow create: if isReferee()
        && request.resource.data.referee_id == request.auth.uid;
      allow update: if isManager()
        && request.auth.uid == resource.data.manager_id;
      allow delete: if isAuth() &&
        (request.auth.uid == resource.data.manager_id ||
         request.auth.uid == resource.data.referee_id);
    }

    // ── Independent Games (referee-private) ───────────────────────────────────
    match /independent_games/{gameId} {
      allow read: if isReferee() &&
        request.auth.uid == resource.data.referee_id;
      allow create: if isReferee() &&
        request.resource.data.referee_id == request.auth.uid;
      allow update, delete: if isReferee() &&
        request.auth.uid == resource.data.referee_id;
    }

    // ── Rate Limits (server-only — no client access) ────────────────────────
    match /_rate_limits/{docId} {
      allow read, write: if false;
    }

    // ── Audit Log (append-only for authenticated users) ─────────────────────
    match /_audit_log/{logId} {
      allow create: if isAuth()
        && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ── Import History (users can CRUD their own import records) ─────────────
    match /_import_history/{historyId} {
      allow read: if isAuth() && request.auth.uid == resource.data.user_id;
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuth() && request.auth.uid == resource.data.user_id;
      allow update: if false;
    }

    // ── AI Chat History (one doc per user, user-only access) ─────────────────
    match /_ai_chat_history/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ── Game Reminders (server-managed — no client access) ──────────────────
    match /_game_reminders/{reminderId} {
      allow read, write: if false;
    }

    // ── FCM Tokens (user-only write, server-only read for push delivery) ────
    match /_fcm_tokens/{userId} {
      allow read: if false;
      allow create, update: if isAuth() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Tournament Brackets (manager-only write, all auth read for real-time) ─
    match /tournament_brackets/{bracketId} {
      allow read: if isAuth();
      allow create: if isManager()
        && request.resource.data.manager_id == request.auth.uid;
      allow update, delete: if isManager()
        && request.auth.uid == resource.data.manager_id;
    }
  }
}
