rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isManager() {
      return isAuth() && getRole() == 'manager';
    }

    function isReferee() {
      return isAuth() && getRole() == 'referee';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Authenticated users can read any profile; unauthenticated can read referee profiles (public)
      allow read: if isAuth() || resource.data.role == 'referee';
      allow create: if isAuth() && request.auth.uid == userId;
      // Prevent role-escalation: users cannot modify their own `role` field
      allow update: if isAuth() && request.auth.uid == userId
        && !('role' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Meta (seed guard) ─────────────────────────────────────────────────────
    // Read: any auth'd user can check the seed guard.
    // Write: only allowed if the doc does not yet exist (prevents re-seeding).
    match /_meta/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && resource == null;
    }

    // ── Tournaments ───────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update, delete: if isManager() && resource.data.manager_id == request.auth.uid;
    }

    // ── Games ─────────────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isManager() && resource.data.manager_id == request.auth.uid;
      allow delete: if isManager() && resource.data.manager_id == request.auth.uid;
    }

    // ── Game Assignments ──────────────────────────────────────────────────────
    match /game_assignments/{assignmentId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        (isManager() || isReferee());
      allow update: if isAuth() &&
        (isManager() || request.auth.uid == resource.data.referee_id);
      allow delete: if isManager();
    }

    // ── Payments ──────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.manager_id ||
         request.auth.uid == resource.data.referee_id);
      allow create: if isManager() &&
        request.resource.data.amount is number &&
        request.resource.data.amount >= 0 &&
        request.resource.data.amount <= 10000;
      allow update: if isManager() && resource.data.manager_id == request.auth.uid;
    }

    // ── Messages ──────────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isAuth() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuth();
      allow update: if isAuth() &&
        request.auth.uid in resource.data.participants;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // H4 fix: tightened from `isAuth()` (any user could spam anyone)
    // Rules now enforce:
    //   • Required fields must be present on every new notification
    //   • Managers can create any notification type (assignments, payments, etc.)
    //   • Referees/others can only create 'message' type notifications (replies)
    //   • Recipients can mark their own notifications as read (update)
    match /notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.recipient_id;
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['recipient_id', 'type', 'title'])
        && (isManager() || request.resource.data.type == 'message');
      allow update: if isAuth() && request.auth.uid == resource.data.recipient_id;
    }

    // ── Referee Availability ──────────────────────────────────────────────────
    match /referee_availability/{availId} {
      allow read: if isAuth();
      allow create, update, delete: if isReferee() &&
        (resource == null || request.auth.uid == resource.data.referee_id);
    }

    // ── Game Reports ──────────────────────────────────────────────────────────
    match /game_reports/{reportId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.referee_id ||
         request.auth.uid == resource.data.manager_id);
      allow create: if isReferee();
      allow update: if isAuth() &&
        (request.auth.uid == resource.data.referee_id ||
         request.auth.uid == resource.data.manager_id);
    }

    // ── Referee Ratings ───────────────────────────────────────────────────────
    // Public read for individual referee ratings (supports public profile).
    // Managers see all, referees see own, unauthenticated see by referee_id.
    match /referee_ratings/{ratingId} {
      allow read: if isAuth() || true;
      allow create: if isManager() &&
        request.resource.data.stars is number &&
        request.resource.data.stars >= 1 &&
        request.resource.data.stars <= 5;
      // Managers can only update ratings they originally created
      allow update: if isManager() && resource.data.manager_id == request.auth.uid &&
        request.resource.data.stars is number &&
        request.resource.data.stars >= 1 &&
        request.resource.data.stars <= 5;
    }

    // ── Manager Connections ───────────────────────────────────────────────────
    match /manager_connections/{connId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.manager_id ||
         request.auth.uid == resource.data.referee_id);
      allow create: if isReferee();
      allow update: if isAuth() &&
        (request.auth.uid == resource.data.manager_id ||
         request.auth.uid == resource.data.referee_id);
      allow delete: if isAuth() &&
        (request.auth.uid == resource.data.manager_id ||
         request.auth.uid == resource.data.referee_id);
    }

    // ── Independent Games (referee-private) ───────────────────────────────────
    match /independent_games/{gameId} {
      allow read, create, update, delete: if isReferee() &&
        (resource == null || request.auth.uid == resource.data.referee_id);
    }

    // ── Rate Limits (server-only — no client access) ────────────────────────
    match /_rate_limits/{docId} {
      allow read, write: if false;
    }

    // ── Audit Log (append-only for authenticated users, read for admins) ────
    match /_audit_log/{logId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }
  }
}
