# iWhistle — Environment Variables
# Copy this file to .env and fill in your Firebase project values.
# Never commit .env to version control.

# ── Firebase ──────────────────────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Firebase Cloud Messaging ───────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → Cloud Messaging → Web configuration → Key pair
VITE_FIREBASE_VAPID_KEY=

# ── Demo Accounts (optional — only needed if you use the "Try Demo" login button) ─
# These are intentionally public credentials for the demonstration accounts.
VITE_DEMO_MANAGER_PASSWORD=
VITE_DEMO_REFEREE_PASSWORD=

# ── Error Monitoring (optional) ─────────────────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=
